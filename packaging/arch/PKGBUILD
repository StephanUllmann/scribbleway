# Maintainer: Stephan Ullmann <stephan@example.com>

pkgname=scribbleway-git
pkgver=0.1.r0.g86a8a1c
pkgrel=1
pkgdesc="A modern, Excalidraw-style screen annotation utility designed for Wayland and KDE Plasma 6"
arch=('x86_64')
url="https://github.com/StephanUllmann/scribbleway"
license=('GPL-2.0-or-later')
depends=('plasma-desktop' 'layer-shell-qt' 'kglobalaccel' 'kdbusaddons' 'qt6-declarative' 'qt6-base')
makedepends=('git' 'cmake' 'extra-cmake-modules')
provides=('scribbleway')
conflicts=('scribbleway')
source=("git+https://github.com/StephanUllmann/scribbleway.git")
md5sums=('SKIP')

pkgver() {
  cd "$srcdir/${pkgname%-git}"
  if git describe --long --tags >/dev/null 2>&1; then
    git describe --long --tags | sed 's/\([^-]*-\)g/r\1/;s/-/./g'
  else
    printf "0.1.r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
  fi
}

build() {
  cmake -B build -S "${pkgname%-git}" \
    -DCMAKE_BUILD_TYPE=None \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DKDE_INSTALL_LIBDIR=lib \
    -DKDE_INSTALL_USE_QT_SYS_PATHS=ON \
    -DBUILD_DEB_PACKAGE=OFF
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
